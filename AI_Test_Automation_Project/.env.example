# ─── Choose ONE AI provider ───────────────────────────────────────────────
# Options: mock | gemini | groq | ollama | openai
# Use "mock" for assignment (no API key, no credits needed)
AI_PROVIDER=mock

# ─── Google Gemini (FREE) ─────────────────────────────────────────────────
# 1. Go to https://aistudio.google.com/apikey
# 2. Create API key → paste below
# 3. Set AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Groq (FREE tier) ─────────────────────────────────────────────────────
# 1. Go to https://console.groq.com/
# 2. Sign up → API Keys → Create
# 3. Set AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Ollama (100% FREE, runs on your PC, no API key) ───────────────────────
# 1. Install from https://ollama.com/download
# 2. Run: ollama pull llama3.2
# 3. Set AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── OpenAI (paid credits) ────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Target web application under test
BASE_URL=https://www.saucedemo.com/
